rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// OnlyLogic — working rules (deploy this one now).
//
//   firebase deploy --only firestore:rules
//   …or paste into Firebase console → Firestore → Rules → Publish.
//
// Access control for the back office is enforced in the app via roles. These
// rules keep the data safe at the boundary (only signed-in users, public site
// limited to creating bookings + reading products) while letting the first
// admin bootstrap without a chicken-and-egg lockout.
//
// Once you've signed in once (your admin account is created) AND added your
// team, you can switch to the stricter, role-aware rules in
// `firestore.rules.strict` for server-side per-module enforcement.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    // A staff account has a member doc; clients do not.
    function isStaff() { return signedIn() && exists(/databases/$(database)/documents/members/$(request.auth.uid)); }

    // Marketing site: the lead form creates bookings; the storefront reads products.
    match /bookings/{id} {
      allow create: if true;
      allow read, update, delete: if signedIn();
    }
    match /products/{id} {
      allow read: if true;
      allow write: if signedIn();
    }

    // Projects — staff manage everything; the linked client may read their own
    // project and may only mutate requirement responses + payment milestones.
    match /projects/{id} {
      allow read: if isStaff() || (signedIn() && resource.data.clientUid == request.auth.uid);
      allow create, delete: if isStaff();
      allow update: if isStaff()
        || (signedIn() && resource.data.clientUid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['requirementResponses', 'requirementStatus', 'requirementSubmittedAt', 'paymentMilestones', 'updatedAt']));
    }

    // Client portal logins — a client reads only their own doc; staff manage them.
    match /clientUsers/{uid} {
      allow read: if isStaff() || (signedIn() && request.auth.uid == uid);
      allow write: if isStaff();
    }

    // Back-office collections — any signed-in account; the app's roles decide
    // what each member actually sees and can change.
    match /clients/{id}   { allow read, write: if signedIn(); }
    match /settings/{id}  { allow read, write: if signedIn(); }
    match /roles/{id}     { allow read, write: if signedIn(); }
    match /members/{id}   { allow read, write: if signedIn(); }

    match /auditLogs/{id} {
      allow create: if signedIn();
      allow read:   if signedIn();
      allow update, delete: if false; // audit trail is append-only
    }
  }
}
